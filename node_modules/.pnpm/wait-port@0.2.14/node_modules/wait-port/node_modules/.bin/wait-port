#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/phil/Dev/lime-soda/web-components/node_modules/.pnpm/wait-port@0.2.14/node_modules/wait-port/bin/node_modules:/Users/phil/Dev/lime-soda/web-components/node_modules/.pnpm/wait-port@0.2.14/node_modules/wait-port/node_modules:/Users/phil/Dev/lime-soda/web-components/node_modules/.pnpm/wait-port@0.2.14/node_modules:/Users/phil/Dev/lime-soda/web-components/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/phil/Dev/lime-soda/web-components/node_modules/.pnpm/wait-port@0.2.14/node_modules/wait-port/bin/node_modules:/Users/phil/Dev/lime-soda/web-components/node_modules/.pnpm/wait-port@0.2.14/node_modules/wait-port/node_modules:/Users/phil/Dev/lime-soda/web-components/node_modules/.pnpm/wait-port@0.2.14/node_modules:/Users/phil/Dev/lime-soda/web-components/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../bin/wait-port.js" "$@"
else
  exec node  "$basedir/../../bin/wait-port.js" "$@"
fi
