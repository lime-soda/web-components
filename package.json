{
  "name": "@lime-soda/web-components",
  "version": "0.0.0",
  "description": "Lime Soda Design System Web Components",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "eslint \"packages/**/*.{ts,tsx}\" \"apps/**/*.{ts,tsx}\"",
    "test": "turbo test",
    "clean": "turbo clean",
    "storybook": "pnpm --filter storybook dev",
    "build-storybook": "pnpm --filter storybook build",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "prepare": "husky"
  },
  "keywords": [
    "design-system",
    "web-components",
    "lit"
  ],
  "author": "Phil Parsons",
  "license": "MIT",
  "packageManager": "pnpm@10.12.1",
  "devDependencies": {
    "turbo": "^2.2.3",
    "@changesets/cli": "^2.27.9",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3",
    "eslint": "^9.15.0",
    "@eslint/js": "^9.15.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "apps/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
