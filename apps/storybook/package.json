{
  "name": "storybook",
  "version": "0.0.0",
  "description": "Storybook for Lime Soda Design System",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "storybook build",
    "test": "test-storybook",
    "test:ci": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"pnpm build-storybook --quiet\" \"wait-on tcp:6006 && pnpm test\""
  },
  "dependencies": {
    "@lime-soda/button": "workspace:*",
    "@lime-soda/input": "workspace:*",
    "@lime-soda/card": "workspace:*",
    "@lime-soda/core": "workspace:*"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.4.6",
    "@storybook/addon-interactions": "^8.4.6",
    "@storybook/addon-links": "^8.4.6",
    "@storybook/blocks": "^8.4.6",
    "@storybook/test": "^8.4.6",
    "@storybook/test-runner": "^0.19.1",
    "@storybook/web-components": "^8.4.6",
    "@storybook/web-components-vite": "^8.4.6",
    "concurrently": "^9.1.0",
    "lit": "^3.3.0",
    "storybook": "^8.4.6",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  }
}
